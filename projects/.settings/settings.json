{
	// Configure glob patterns for excluding files and folders.
	"files.exclude": {
		"**/.git": true,
		"**/.DS_Store": true,
		"**/*.js.map": true,
		"**/obj": true,
		"**/bin": true,
		"**/*.js": true,
		"**/*.csproj*": true,
		"**/*.sln": true,
		"**/*.config": true,
		"**/*.suo": true
	}
}